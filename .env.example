# Telegram Bot Token
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# GigaChat API credentials
# Вариант 1: Использование AUTH_KEY (рекомендуется)
GIGACHAT_AUTH_KEY=your_auth_key_here
GIGACHAT_SCOPE=GIGACHAT_API_PERS

# Вариант 2: Использование CLIENT_ID и CLIENT_SECRET (альтернатива)
# GIGACHAT_CLIENT_ID=your_client_id_here
# GIGACHAT_CLIENT_SECRET=your_client_secret_here

# GigaChat API URLs (опционально, используются значения по умолчанию)
# GIGACHAT_API_AUTH_URL=https://ngw.devices.sberbank.ru:9443/api/v2/oauth
# GIGACHAT_API_CHAT_URL=https://gigachat.devices.sberbank.ru/api/v1/chat/completions

# Database (optional, for storing news)
DATABASE_URL=sqlite:///news.db

# Admin user IDs (comma-separated, опционально - для административных функций)
ADMIN_IDS=

# Канал/группа для публикации сводок (ID канала/группы или username)
# Примеры: SUMMARY_CHAT_ID=-1001234567890 или SUMMARY_CHAT_ID=@my_channel
# Если указан, сводки будут публиковаться в этот канал/группу
# Если не указан, сводки будут отправляться администраторам (если указаны ADMIN_IDS)
SUMMARY_CHAT_ID=

# Update interval in minutes
UPDATE_INTERVAL=60

# Telegram Client API credentials (для чтения публичных каналов)
# Получите на https://my.telegram.org/apps
TELEGRAM_API_ID=your_api_id_here
TELEGRAM_API_HASH=your_api_hash_here
TELEGRAM_PHONE=+7XXXXXXXXXX